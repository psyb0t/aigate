# LiteLLM
LITELLM_MASTER_KEY=sk-change-me-to-something-secret

# Postgres
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://litellm:change-me-strong-password@postgres:5432/litellm

# Redis
REDIS_PASSWORD=change-me-redis-password

# LiteLLM Admin UI — accessible at /ui/ (rate limited at 30r/m)
# LITELLM_UI_BASIC_AUTH: nginx basic auth layer (optional, leave empty to disable)
# LITELLM_USERNAME/PASSWORD: LiteLLM's own UI login credentials
LITELLM_UI_BASIC_AUTH=admin:change-me-password
LITELLM_USERNAME=admin
LITELLM_PASSWORD=change-me-ui-password

# Workers (tune to CPU cores)
LITELLM_WORKERS=4

# ── Enable/disable providers and services ────────────────────────────────────
# Set to 1 to enable. Keys/tokens must also be set below.
# Providers not enabled here are excluded from the model list and fallback chains.
OPENAI=
ANTHROPIC=
CLAUDEBOX=
CLAUDEBOX_ZAI=
CEREBRAS=
OPENROUTER=
HUGGINGFACE=
MISTRAL=
COHERE=
GROQ=
OLLAMA=      # local CPU inference (~6GB+ RAM for all models)
SPEACHES=    # local transcription/TTS (~4GB RAM)
BROWSER=     # stealth browser cluster (5 Camoufox replicas, ~1.3GB RAM)
HYBRIDS3=    # object storage service + MCP server

# ── Internal tokens ───────────────────────────────────────────────────────────
CLAUDEBOX_API_TOKEN=change-me
CLAUDEBOX_ZAI_API_TOKEN=change-me-zai

# ── claudebox (Claude Code via OAuth or Anthropic API key) ───────────────────
# OAuth: claude setup-token (requires Claude Pro/Max/Team subscription)
CLAUDE_CODE_OAUTH_TOKEN=
# API key: https://console.anthropic.com/settings/keys (pay-per-use)
# CLAUDEBOX_ANTHROPIC_API_KEY=

# ── claudebox-zai (Claude Code via z.ai — GLM models) ────────────────────────
# Get token: https://z.ai
CLAUDEBOX_ZAI_AUTH_TOKEN=
ZAI_OPUS_MODEL=glm-5.1
ZAI_SONNET_MODEL=glm-4.7
ZAI_HAIKU_MODEL=glm-4.5-air

# ── Groq (free tier) — https://console.groq.com ───────────────────────────────
GROQ_API_KEY=gsk_...

# ── HuggingFace (free tier) — https://huggingface.co/settings/tokens ─────────
HF_TOKEN=hf_...

# ── Cerebras (free: 1M tokens/day) — https://cloud.cerebras.ai ───────────────
CEREBRAS_API_KEY=csk-...

# ── OpenRouter (free tier: 50 req/day, 1000/day with $10+) — https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# ── Mistral AI (free: 1B tokens/month, 60 RPM) — https://console.mistral.ai ──
# MISTRAL_API_KEY=...

# ── Cohere (trial: 1K RPD, 20 RPM, all chat models) — https://dashboard.cohere.com
# COHERE_API_KEY=...

# ── OpenAI — https://platform.openai.com/api-keys ────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic — https://console.anthropic.com/settings/keys ──────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Stealthy Auto Browse cluster ──────────────────────────────────────────────
STEALTHY_AUTO_BROWSE_AUTH_TOKEN=change-me-browser-auth
STEALTHY_AUTO_BROWSE_REDIS_PASSWORD=change-me-browser-redis
STEALTHY_AUTO_BROWSE_NUM_REPLICAS=5
STEALTHY_AUTO_BROWSE_QUEUE_TIMEOUT=300

# ── Cloudflared — expose via Cloudflare Tunnel (optional) ────────────────────
# Without config/creds a random *.trycloudflare.com URL is assigned (no account needed).
# Named tunnel docs: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/
CLOUDFLARED=
CLOUDFLARED_CONFIG=
CLOUDFLARED_CREDS=

# ── HybridS3 — object storage at /storage/ ───────────────────────────────────
HYBRIDS3_MASTER_KEY=change-me-master-key
HYBRIDS3_UPLOADS_KEY=change-me-uploads-key
HYBRIDS3_UPLOADS_TTL=168h
HYBRIDS3_UPLOADS_MAX_SIZE=100MB
