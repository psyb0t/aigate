# LiteLLM
LITELLM_MASTER_KEY=sk-change-me-to-something-secret

# Postgres
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://litellm:change-me-strong-password@postgres:5432/litellm

# Redis
REDIS_PASSWORD=change-me-redis-password

# LiteLLM Admin UI — accessible at /ui/ (rate limited at 5 req/min)
# Optional — leave empty to disable basic auth
LITELLM_UI_BASIC_AUTH=admin:change-me-password

# Workers (tune to CPU cores)
WORKERS=4

# Internal tokens for claudebox containers
CLAUDEBOX_API_TOKEN=change-me
CLAUDEBOX_ZAI_API_TOKEN=change-me-zai

# Claudebox auth — use EITHER OAuth token OR Anthropic API key (one is enough)
# Enables the claudebox profile (Claude Code via your subscription or API key)
# OAuth: claude setup-token (requires Claude Pro/Max/Team subscription)
CLAUDE_CODE_OAUTH_TOKEN=
# API key: https://console.anthropic.com/settings/keys (pay-per-use)
# CLAUDEBOX_ANTHROPIC_API_KEY=

# z.ai auth token — enables the claudebox-zai profile (GLM models via z.ai)
# Get it: https://z.ai
ZAI_AUTH_TOKEN=
ZAI_OPUS_MODEL=glm-5.1
ZAI_SONNET_MODEL=glm-4.7
ZAI_HAIKU_MODEL=glm-4.5-air

# Groq (free tier) — https://console.groq.com
GROQ_API_KEY=gsk_...

# HuggingFace (free tier) — https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Cerebras (free: 1M tokens/day) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...

# OpenRouter (free tier: 50 req/day, 1000/day with $10+ loaded) — https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Mistral AI (free: 1B tokens/month, 60 RPM) — https://console.mistral.ai
# MISTRAL_API_KEY=...

# Cohere (trial: 1K RPD, 20 RPM, all chat models) — https://dashboard.cohere.com
# COHERE_API_KEY=...

# Optional — only needed if you want OpenAI models
# OPENAI_API_KEY=sk-...

# Optional — only needed if you want direct Anthropic API models
# ANTHROPIC_API_KEY=sk-ant-...

# Stealthy Auto Browse cluster — browser automation at /stealthy-auto-browse/
# Optional — leave empty to disable auth
STEALTHY_AUTO_BROWSE_AUTH_TOKEN=change-me-browser-auth
STEALTHY_AUTO_BROWSE_REDIS_PASSWORD=change-me-browser-redis
STEALTHY_AUTO_BROWSE_NUM_REPLICAS=5
STEALTHY_AUTO_BROWSE_QUEUE_TIMEOUT=300

# Cloudflared — expose the gateway via Cloudflare Tunnel (optional)
# Set CLOUDFLARED=1 to enable. Without config/creds a random *.trycloudflare.com
# URL is assigned automatically (no account needed).
# Named tunnel docs: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/
CLOUDFLARED=
CLOUDFLARED_CONFIG=
CLOUDFLARED_CREDS=

# HybridS3 — object storage at /storage/ (S3 + plain HTTP + MCP)
HYBRIDS3_MASTER_KEY=change-me-master-key
HYBRIDS3_UPLOADS_KEY=change-me-uploads-key
HYBRIDS3_UPLOADS_TTL=168h
HYBRIDS3_UPLOADS_MAX_SIZE=100MB
