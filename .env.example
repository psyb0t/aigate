# ── Core ─────────────────────────────────────────────────────────────────────

LITELLM_MASTER_KEY=sk-change-me-to-something-secret

POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://litellm:change-me-strong-password@postgres:5432/litellm

REDIS_PASSWORD=change-me-redis-password

LITELLM_WORKERS=4

# LiteLLM Admin UI (/ui/, rate limited at 30r/m)
# LITELLM_UI_BASIC_AUTH: nginx basic auth (optional, leave empty to disable)
# LITELLM_USERNAME/PASSWORD: LiteLLM's own UI login
LITELLM_UI_BASIC_AUTH=admin:change-me-password
LITELLM_USERNAME=admin
LITELLM_PASSWORD=change-me-ui-password

# ── What's enabled ────────────────────────────────────────────────────────────
# Set to 1 to enable. Credentials must also be filled in below.
# Disabled providers are excluded from the model list and fallback chains.

CLAUDEBOX=        # Claude Code via OAuth/API key
CLAUDEBOX_ZAI=    # Claude Code via z.ai (GLM models)
GROQ=             # Groq (free tier)
CEREBRAS=         # Cerebras (free tier)
OPENROUTER=       # OpenRouter (free tier)
HUGGINGFACE=      # HuggingFace (free tier)
MISTRAL=          # Mistral AI (free tier)
COHERE=           # Cohere (trial)
ANTHROPIC=        # Anthropic (pay-per-token)
OPENAI=           # OpenAI (pay-per-token)
OLLAMA=           # Local CPU inference (~6GB+ RAM)
SPEACHES=         # Local transcription/TTS (~4GB RAM)
BROWSER=          # Stealth browser cluster (~1.3GB RAM)
HYBRIDS3=         # Object storage + MCP
CLOUDFLARED=      # Cloudflare Tunnel (public exposure)

# ── Credentials ───────────────────────────────────────────────────────────────

# claudebox — OAuth: claude setup-token (Pro/Max/Team sub)
CLAUDEBOX_API_TOKEN=change-me
CLAUDE_CODE_OAUTH_TOKEN=
# or API key: https://console.anthropic.com/settings/keys
# CLAUDEBOX_ANTHROPIC_API_KEY=

# claudebox-zai — https://z.ai
CLAUDEBOX_ZAI_API_TOKEN=change-me-zai
CLAUDEBOX_ZAI_AUTH_TOKEN=
ZAI_OPUS_MODEL=glm-5.1
ZAI_SONNET_MODEL=glm-4.7
ZAI_HAIKU_MODEL=glm-4.5-air

# Groq — https://console.groq.com
GROQ_API_KEY=gsk_...

# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-...

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# HuggingFace — https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Mistral — https://console.mistral.ai
# MISTRAL_API_KEY=...

# Cohere — https://dashboard.cohere.com
# COHERE_API_KEY=...

# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Service config ────────────────────────────────────────────────────────────

# Browser cluster
STEALTHY_AUTO_BROWSE_AUTH_TOKEN=change-me-browser-auth
STEALTHY_AUTO_BROWSE_REDIS_PASSWORD=change-me-browser-redis
STEALTHY_AUTO_BROWSE_NUM_REPLICAS=5
STEALTHY_AUTO_BROWSE_QUEUE_TIMEOUT=300

# HybridS3
HYBRIDS3_MASTER_KEY=change-me-master-key
HYBRIDS3_UPLOADS_KEY=change-me-uploads-key
HYBRIDS3_UPLOADS_TTL=168h
HYBRIDS3_UPLOADS_MAX_SIZE=100MB

# Rate limits (nginx) — format: Nr/m or Nr/s
# RATELIMIT_ADMIN=30r/m         # admin UI (/ui, /login)
# RATELIMIT_ADMIN_BURST=20
# RATELIMIT_API=120r/m          # LiteLLM API (/)
# RATELIMIT_API_BURST=30
# RATELIMIT_STORAGE=60r/m       # hybrids3 (/storage)
# RATELIMIT_STORAGE_BURST=20
# RATELIMIT_CLAUDEBOX=30r/m     # claudebox (/claudebox/, /claudebox-zai/)
# RATELIMIT_CLAUDEBOX_BURST=10
# RATELIMIT_BROWSER=30r/m       # browser cluster (/stealthy-auto-browse/)
# RATELIMIT_BROWSER_BURST=10
# RATELIMIT_PROXQ=120r/m        # proxq async queue (/q/)
# RATELIMIT_PROXQ_BURST=30

# Nginx timeouts (proxy_read_timeout / proxy_send_timeout)
# NGINX_MAX_BODY_SIZE=50m       # max upload size
# TIMEOUT_ADMIN=60s             # admin UI (/ui, /login)
# TIMEOUT_API=600s              # LiteLLM API (/)
# TIMEOUT_CLAUDEBOX=600s        # claudebox (/claudebox/, /claudebox-zai/)
# TIMEOUT_BROWSER=600s          # browser cluster (/stealthy-auto-browse/)
# TIMEOUT_PROXQ=30s             # proxq submit (/q/) — fast, just enqueues

# Proxq
# PROXQ_CONCURRENCY=10          # worker concurrency
# PROXQ_TASK_RETENTION=1h       # how long completed jobs stay in Redis
# PROXQ_UPSTREAM_TIMEOUT=10m    # max time to wait for LiteLLM response

# Cloudflared — named tunnel docs: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/
# Without config/creds a random *.trycloudflare.com URL is assigned (no account needed)
CLOUDFLARED_CONFIG=
CLOUDFLARED_CREDS=
